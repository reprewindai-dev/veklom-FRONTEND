# ─── Veklom Control Plane – Production Environment ───────────────────────────
# Set these in Coolify's environment variable panel for the control-plane service.

# Backend service URL used SERVER-SIDE by next.config.mjs rewrites.
# In Coolify: set this to the backend's internal service URL (e.g. http://veklom-api:8088)
# or the public-facing backend URL if on the same domain.
BACKEND_URL=https://veklom.com

# Dedicated VNP operational service. Keep this separate from the generic
# backend fallback so VNP proof routes cannot silently target BYOS.
VNP_API_BASE_URL=https://vnp.veklom.com

# CAPPO settlement/staking authority. The public staking route may require
# authentication; do not replace it with a different backend for a 200.
CAPPO_API_BASE_URL=https://cappo.veklom.com

# Public-facing base URL (baked into the client bundle at build time)
NEXT_PUBLIC_API_BASE_URL=https://veklom.com
