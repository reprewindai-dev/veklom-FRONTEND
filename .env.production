# CRITICAL: Leave NEXT_PUBLIC_API_BASE_URL empty so the browser hits same-origin /api/*
# Next.js rewrites in next.config.mjs proxy /api/* → BACKEND_URL on the server side.
# Setting this to https://api.veklom.com causes browser CORS failures.
NEXT_PUBLIC_API_BASE_URL=

BACKEND_URL=https://api.veklom.com
PGL_URL=https://pgl.veklom.com
CAPPO_URL=https://cappo.veklom.com
VNP_URL=https://vnp.veklom.com
LOCKERPHYCER_URL=https://lockerphycer.veklom.com
APEX_URL=https://apex.veklom.com
ABIDE_URL=https://abide.veklom.com

NEXT_PUBLIC_REPOGATE_URL=https://repogate.veklom.com
